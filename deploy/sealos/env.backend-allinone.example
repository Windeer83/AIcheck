APP_ENV=sealos
APP_ACCESS_TOKEN=replace-with-a-long-random-token
BACKEND_CORS_ORIGINS=https://replace-web-domain

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres
CELERY_BROKER_URL=redis://default:PASSWORD@REDIS_HOST:6379/0
CELERY_RESULT_BACKEND=redis://default:PASSWORD@REDIS_HOST:6379/1

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/data

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

RETRIEVAL_TOP_K=12
EVIDENCE_TOP_N=5
