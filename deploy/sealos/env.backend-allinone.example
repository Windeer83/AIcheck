APP_ENV=sealos
APP_ACCESS_TOKEN=replace-with-a-long-random-token
BACKEND_CORS_ORIGINS=https://replace-web-domain

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres
CELERY_BROKER_URL=redis://default:PASSWORD@REDIS_HOST:6379/0
CELERY_RESULT_BACKEND=redis://default:PASSWORD@REDIS_HOST:6379/1

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/data

LLM_PROVIDER=openai_compatible
OPENAI_API_KEY=replace-with-siliconflow-key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=deepseek-ai/DeepSeek-V4-Pro
EMBEDDING_MODEL=BAAI/bge-m3

RETRIEVAL_TOP_K=12
EVIDENCE_TOP_N=5
OPENALEX_API_KEY=
OPENALEX_EMAIL=
OPENALEX_PER_CLAIM_LIMIT=5
OPENALEX_TIMEOUT_SECONDS=12
