APP_ENV=sealos
APP_ACCESS_TOKEN=replace-with-the-same-token-as-api

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
CELERY_BROKER_URL=redis://REDIS_HOST:6379/0
CELERY_RESULT_BACKEND=redis://REDIS_HOST:6379/1

STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://replace-internal-s3-endpoint
S3_ACCESS_KEY_ID=replace-access-key
S3_SECRET_ACCESS_KEY=replace-secret-key
S3_BUCKET=replace-bucket
S3_REGION=auto

LLM_PROVIDER=openai_compatible
OPENAI_API_KEY=replace-openai-compatible-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

RETRIEVAL_TOP_K=12
EVIDENCE_TOP_N=5

